@dataclass
class Config:
    image_path:  str   = '/content/myhand.jpg'
    model_dir:   str   = '/content'          
    output_dir:  str   = '/content/output'
    model_paths: dict  = field(default_factory=lambda: {
        'sinh_dao':  'sinhdao30.h5',
        'tam_dao':   'tamdao30.h5',
        'tri_dao':   'tridao30.h5',
        'su_nghiep': 'sunghiep30.h5',   
    })
    crop_size:   int   = 200
    num_hands:   int   = 1

    def get_model_path(self, key: str) -> str:
        return os.path.join(self.model_dir, self.model_paths[key])

CFG = Config()
os.makedirs(CFG.output_dir, exist_ok=True)
